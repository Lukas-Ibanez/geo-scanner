# Copia este archivo a `.dev.vars` (NO lo subas a git) y completa tu clave.
# Obtén una clave gratis en https://aistudio.google.com/app/apikey
GEMINI_API_KEY=tu_clave_de_google_ai_studio

# --- Claude (API de Anthropic) ---
# Necesario si usas AI_PROVIDER=claude o el informe detallado. Es de pago: crea
# una clave en https://platform.claude.com (Console → API keys).
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# --- Informe detallado (nivel 'detailed', de pago) ---
# Passphrase que desbloquea el informe detallado (comparación con competidores +
# preguntas-cliente). Es TEMPORAL: reemplázala por una verificación de pago real
# cuando se cobre. Si se omite, nadie accede al nivel 'detailed'.
# DETAILED_PASSPHRASE=cambia-esto-por-una-frase-secreta
# Modelo del informe detallado (default: claude-haiku-4-5).
# DETAILED_MODEL=claude-haiku-4-5

# --- Envío del informe por correo (Resend) ---
# Clave gratis en https://resend.com (3.000 emails/mes). Si se omite, no se envía
# correo (el informe igual se muestra en pantalla y el lead se guarda).
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Remitente: debe estar en un dominio verificado en Resend.
# RESEND_FROM=GEO Scanner <informe@geo.lukasibanez.dev>
# Correo de respuesta (opcional)
# RESEND_REPLY_TO=hola@lukasibanez.dev

# --- Opcionales (tienen defaults razonables en el código) ---
# Modelo de Gemini a usar (capa gratuita de Google AI Studio)
# GEMINI_MODEL=gemini-2.5-flash
# Tope global de llamadas a Gemini por día (protege tu cuota gratuita; 0 = sin tope)
# GEMINI_DAILY_LIMIT=200
# Máximo de escaneos por IP por hora
# RATE_LIMIT_PER_HOUR=5
# IPs sin límite de escaneos, separadas por coma (p.ej. la tuya, para probar)
# RATE_LIMIT_WHITELIST=200.0.0.0,201.0.0.0
# Horas de validez de la caché por dominio
# CACHE_TTL_HOURS=6
# Link de la sección de servicios del portafolio (CTA final)
# PORTFOLIO_CTA_URL=https://lukasibanez.dev/#servicios
# Proveedor de IA para el ESCANEO BASE (capa gratuita):
#   'gemini' (recomendado, default en prod) | 'hybrid' (Gemini + Workers AI fallback) | 'claude' | 'workers-ai'
# (en prod se define en wrangler.toml [vars]; aquí solo para overrides locales).
# NOTA: el informe detallado SIEMPRE usa Claude, esto no lo afecta.
# AI_PROVIDER=gemini
# Override del modelo de Workers AI
# WORKERSAI_MODEL=@cf/meta/llama-3.3-70b-instruct-fp8-fast
# Override del modelo de Claude (default: claude-haiku-4-5)
# ANTHROPIC_MODEL=claude-haiku-4-5
# Tope global de llamadas a Claude por día (Claude es de pago; 0 = sin tope)
# ANTHROPIC_DAILY_LIMIT=200
