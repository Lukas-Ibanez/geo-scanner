---
import Base from '../layouts/Base.astro';
import ScanForm from '../components/ScanForm.astro';

// Landing estática (irónicamente, debe estar bien optimizada para GEO ella misma).
export const prerender = true;

// Flujo de captura del correo. 'one-step' = correo junto a la URL.
// 'two-step' = puntaje gratis + correo para revelar el detalle.
const REVEAL_FLOW: 'one-step' | 'two-step' = 'one-step';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'GEO Scanner',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  inLanguage: 'es',
  url: 'https://geo.lukasibanez.dev',
  description:
    'Herramienta gratuita que audita qué tan preparado está tu sitio web para aparecer en respuestas de IA como ChatGPT, Perplexity, Gemini y Google AI Overviews.',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
};
---

<Base>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />

  <header class="site-header">
    <div class="container">
      <a class="brand" href="/"><span class="dot" aria-hidden="true"></span> GEO Scanner</a>
    </div>
  </header>

  <main>
    <section class="hero">
      <div class="container">
        <span class="eyebrow"><span class="pulse"></span> Optimización para buscadores con IA (GEO)</span>
        <h1>¿Te encuentran <span class="grad">las IA</span> cuando alguien busca lo que vendes?</h1>
        <p class="lead">
          Escanea tu sitio gratis y descubre qué tan preparado está para aparecer en ChatGPT,
          Perplexity, Gemini y Google AI — con un puntaje claro y qué mejorar, sin tecnicismos.
        </p>

        <div class="scan-card card">
          <ScanForm revealFlow={REVEAL_FLOW} />
        </div>

        <ul class="trust">
          <li class="chk">✓ Gratis</li>
          <li class="sep">·</li>
          <li class="chk">✓ En segundos</li>
          <li class="sep">·</li>
          <li class="engines">
            <span class="engine">ChatGPT</span>
            <span class="engine">Perplexity</span>
            <span class="engine">Gemini</span>
            <span class="engine">Google AI</span>
          </li>
        </ul>
      </div>
    </section>

    <section class="container">
      <!-- La island renderiza aquí el loading y el resultado -->
      <div id="scan-output" hidden></div>
    </section>

    <section class="section section-center">
      <div class="container">
        <h2>Cómo funciona</h2>
        <p class="sub">En tres pasos simples obtienes un diagnóstico claro de tu visibilidad ante las IA.</p>
        <div class="steps">
          <article class="step card">
            <span class="num">1</span>
            <h3>Pega tu dirección</h3>
            <p>Escribe la web de tu negocio. No necesitas instalar ni configurar nada.</p>
          </article>
          <article class="step card">
            <span class="num">2</span>
            <h3>Analizamos como una IA</h3>
            <p>Revisamos si las IA pueden leerte, entender qué ofreces y dónde operas.</p>
          </article>
          <article class="step card">
            <span class="num">3</span>
            <h3>Recibe tu plan</h3>
            <p>Un puntaje claro y recomendaciones concretas, en lenguaje de negocio.</p>
          </article>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container">
      <p>GEO Scanner · una herramienta de <a href="https://lukasibanez.dev">lukasibanez.dev</a></p>
    </div>
  </footer>

  <script>
    import { initScanner } from '../scripts/scanner-island';
    initScanner();
  </script>
</Base>
