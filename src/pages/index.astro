---
import Base from '../layouts/Base.astro';

// Landing estática (irónicamente, debe estar bien optimizada para GEO ella misma).
export const prerender = true;

const SITE = 'https://geo.lukasibanez.dev';
const AUTHOR_URL = 'https://lukasibanez.dev';
const GITHUB_URL = 'https://github.com/Lukas-Ibanez';

// FAQ: una sola fuente de verdad → se renderiza visible y alimenta el schema FAQPage.
const faqs = [
  {
    q: '¿Qué es GEO?',
    a: 'GEO (Generative Engine Optimization) es optimizar tu sitio para aparecer y ser citado en las respuestas de los buscadores con IA, como ChatGPT, Perplexity, Gemini y los resúmenes de IA de Google. En vez de competir solo por un lugar en la lista de enlaces, buscas que la IA te entienda y te recomiende dentro de su respuesta.',
  },
  {
    q: '¿En qué se diferencia del SEO?',
    a: 'El SEO busca posicionar tu página entre los enlaces azules de Google. El GEO busca que la inteligencia artificial comprenda qué ofreces, confíe en tu sitio y te cite cuando alguien pregunta por lo que vendes. Son complementarios: un buen SEO ayuda, pero no garantiza que la IA te mencione.',
  },
  {
    q: '¿Es gratis?',
    a: 'Sí. El escaneo, el puntaje y el informe con recomendaciones son gratis. Solo te pido tu correo para enviarte el informe completo; no necesitas crear una cuenta. Si quieres ir más allá, existe un reporte premium (US$5, pago único) con plan de acción priorizado, comparativa contra tus competidores y un PDF profesional.',
  },
  {
    q: '¿Qué necesito para usarlo?',
    a: 'Solo la dirección de tu sitio web. No tienes que instalar nada, ni configurar nada, ni dar acceso a tus cuentas. Pegas la URL y en segundos tienes tu diagnóstico.',
  },
  {
    q: '¿Cómo se calcula el puntaje?',
    a: 'Analizamos tu sitio como lo haría una IA: si los robots de IA pueden leerlo, si queda claro qué ofreces y en qué zona operas, y qué tan citable y confiable es tu contenido. Combinamos esas señales en un puntaje de 0 a 100 con recomendaciones en lenguaje de negocio.',
  },
  {
    q: '¿Qué hacen con mis datos?',
    a: 'Guardamos tu correo y la URL escaneada para enviarte el informe y, si te interesa, contarte cómo implementar las mejoras. No compartimos ni vendemos tu información.',
  },
];

// Casos de uso / industrias. Datos editables: cambia o agrega entradas aquí.
const industries = [
  {
    title: 'Servicios locales',
    who: 'Clínicas, talleres, estudios, salones y oficios.',
    how: 'Cuando alguien le pide a una IA un servicio "cerca de mí", gana el negocio cuya web deja clarísimo qué hace y en qué zona atiende. El GEO se asegura de que ese seas tú.',
  },
  {
    title: 'Tiendas y e-commerce',
    who: 'Comercios con venta online o con local físico.',
    how: 'Las IA recomiendan productos y tiendas dentro de su respuesta. Si tu catálogo y tu propuesta están bien explicados, te citan en vez de mandar al cliente a la competencia.',
  },
  {
    title: 'Profesionales y consultores',
    who: 'Abogados, contadores, agencias, coaches y freelancers.',
    how: 'Tu experiencia es tu activo. El GEO la traduce en señales que la IA reconoce y cita cuando alguien busca a un experto en tu tema.',
  },
  {
    title: 'Turismo y hospitalidad',
    who: 'Hoteles, restaurantes, tours y arriendos.',
    how: 'Los viajeros planifican preguntándole a la IA. Un sitio claro sobre qué ofreces y dónde estás hace que te incluya en sus recomendaciones de viaje.',
  },
];

// Features resumidos (página principal "Qué es")
const features = [
  {
    icon: '🔍',
    title: 'Análisis técnico',
    body: '9 señales objetivas: robots de IA, datos estructurados, metadatos, sitemap y más. Cada una con su peso en el puntaje.',
  },
  {
    icon: '🧠',
    title: 'Análisis de contenido con IA',
    body: 'Una IA evalúa tu sitio en 4 dimensiones: claridad de negocio, citabilidad, autoridad y zona geográfica.',
  },
  {
    icon: '📊',
    title: 'Puntaje de 0 a 100',
    body: 'Un número claro y reproducible, con banda de color (rojo / naranja / verde) para saber de un vistazo dónde estás parado.',
  },
  {
    icon: '📝',
    title: 'Plan de mejoras en lenguaje de negocio',
    body: 'Recomendaciones concretas ordenadas por impacto, sin jerga técnica. Las entiende el dueño del negocio, no solo el dev.',
  },
];

// Metodología: refleja el puntaje real (técnico 40% + contenido 60%).
const techChecks = [
  { w: 25, label: 'Las IA pueden leer tu sitio (no bloqueas a sus robots)' },
  { w: 15, label: 'Datos estructurados que describen tu negocio' },
  { w: 12, label: 'Título de página claro y de buen largo' },
  { w: 12, label: 'Descripción que resume de qué trata el sitio' },
  { w: 12, label: 'Un encabezado principal único' },
  { w: 8, label: 'Listo para verse y citarse bien al compartirlo' },
  { w: 6, label: 'Señala cuál es la versión oficial de cada página' },
  { w: 5, label: 'Mapa del sitio (sitemap) para descubrir sus páginas' },
  { w: 5, label: 'Archivo llms.txt que orienta a las IA' },
];

// Las 4 dimensiones de contenido (ver src/lib/contentShared.ts), promediadas.
const dimensions = [
  { name: 'Claridad de negocio', desc: 'Si queda explícito qué vendes y para quién desde el primer bloque de texto.' },
  { name: 'Citabilidad', desc: 'Si tu contenido está estructurado en respuestas claras que una IA pueda extraer y citar.' },
  { name: 'Autoridad', desc: 'Si hay señales verificables de experiencia: años, clientes, cifras, casos o reseñas.' },
  { name: 'Claridad geográfica', desc: 'Si se entiende en qué ciudad o zona operas (o si claramente eres un negocio 100% digital).' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': `${AUTHOR_URL}/#lukas`,
      name: 'Lukas Ibáñez',
      url: AUTHOR_URL,
      jobTitle: 'Desarrollador web',
      description:
        'Desarrollador web con experiencia real en infraestructura, SEO y sitios en producción. Optimiza sitios para que las IA los encuentren, entiendan y recomienden (GEO).',
      knowsAbout: [
        'GEO (Generative Engine Optimization)',
        'SEO',
        'Desarrollo web',
        'Infraestructura web',
        'Cloudflare',
      ],
      sameAs: [AUTHOR_URL, GITHUB_URL],
    },
    {
      '@type': 'Organization',
      '@id': `${AUTHOR_URL}/#organization`,
      name: 'Lukas Ibáñez',
      url: AUTHOR_URL,
      founder: { '@id': `${AUTHOR_URL}/#lukas` },
      areaServed: ['CL', 'Latinoamérica', 'España'],
      knowsLanguage: 'es',
      sameAs: [GITHUB_URL],
      description:
        'Desarrollo web y optimización para buscadores con IA (GEO), con base en Chile y enfoque en negocios de habla hispana.',
    },
    {
      '@type': 'WebApplication',
      '@id': `${SITE}/#webapp`,
      name: 'GEO Scanner',
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Web',
      inLanguage: 'es-CL',
      url: SITE,
      description:
        'Herramienta gratuita que audita qué tan preparado está tu sitio web para aparecer en respuestas de IA como ChatGPT, Perplexity, Gemini y Google AI Overviews. Hecha en Chile para negocios de habla hispana.',
      isAccessibleForFree: true,
      offers: [
        { '@type': 'Offer', name: 'Escaneo GEO gratis', price: '0', priceCurrency: 'USD' },
        {
          '@type': 'Offer',
          name: 'Reporte GEO premium',
          description:
            'Informe detallado con plan de acción priorizado, comparativa con competidores y reporte PDF profesional.',
          price: '5',
          priceCurrency: 'USD',
        },
      ],
      author: { '@id': `${AUTHOR_URL}/#lukas` },
      creator: { '@id': `${AUTHOR_URL}/#lukas` },
      publisher: { '@id': `${AUTHOR_URL}/#organization` },
      audience: {
        '@type': 'Audience',
        audienceType: 'Dueños de negocios y emprendedores de habla hispana',
        geographicArea: { '@type': 'Place', name: 'Latinoamérica y España' },
      },
    },
    {
      '@type': 'FAQPage',
      '@id': `${SITE}/#faq`,
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
  ],
};
---

<Base active="home">
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />

  <main>
    <!-- ===== Hero ===== -->
    <section class="hero">
      <div class="container">
        <span class="eyebrow"><span class="pulse"></span> Optimización para buscadores con IA (GEO)</span>
        <h1>¿Te encuentran <span class="grad">las IA</span> cuando alguien busca lo que vendes?</h1>
        <p class="lead">
          Escanea tu sitio gratis y descubre qué tan preparado está para aparecer en ChatGPT,
          Perplexity, Gemini y Google AI — con un puntaje claro y qué mejorar, sin tecnicismos.
        </p>

        <div class="hero-cta">
          <a class="btn btn-primary btn-lg" href="/scan">
            Escanear mi sitio gratis
            <span class="arrow" aria-hidden="true">→</span>
          </a>
          <a class="btn btn-ghost" href="#how">Ver cómo funciona</a>
        </div>

        <ul class="trust">
          <li class="chk">✓ Gratis</li>
          <li class="sep">·</li>
          <li class="chk">✓ En segundos</li>
          <li class="sep">·</li>
          <li class="chk">✓ Sin instalar nada</li>
          <li class="sep">·</li>
          <li class="engines">
            <span class="engine">ChatGPT</span>
            <span class="engine">Perplexity</span>
            <span class="engine">Gemini</span>
            <span class="engine">Google AI</span>
          </li>
        </ul>

        <p class="author-trust">
          Hecho en Chile por <a href={AUTHOR_URL} rel="author">Lukas Ibáñez</a>, desarrollador web con
          experiencia real en infraestructura, SEO y sitios en producción —
          los mismos fundamentos con que se construyó esta herramienta. Pensada para negocios de
          habla hispana en Latinoamérica y España. <a href={GITHUB_URL} rel="me">Ver código y proyectos</a>.
        </p>
      </div>
    </section>

    <!-- ===== Features (Qué es) ===== -->
    <section class="section" id="features">
      <div class="container">
        <div class="section-head">
          <span class="section-kicker">Qué obtienes</span>
          <h2>Una auditoría completa en segundos</h2>
          <p class="sub">Cuatro bloques de análisis que combinados te dicen exactamente qué tan visible eres para las IA.</p>
        </div>

        <div class="features-grid">
          {
            features.map((f) => (
              <article class="feature card">
                <span class="feature-ico" aria-hidden="true">{f.icon}</span>
                <h3>{f.title}</h3>
                <p>{f.body}</p>
              </article>
            ))
          }
        </div>

        <div class="section-cta">
          <a class="btn btn-primary" href="/scan">Empezar mi diagnóstico</a>
        </div>
      </div>
    </section>

    <!-- ===== Mockup preview del informe ===== -->
    <section class="section section-alt">
      <div class="container">
        <div class="section-head">
          <span class="section-kicker">Así se ve</span>
          <h2>Tu informe, en una sola pantalla</h2>
          <p class="sub">Un puntaje claro, las dimensiones evaluadas y un plan de acción concreto. Esto es un ejemplo.</p>
        </div>

        <div class="preview-card card" aria-hidden="true">
          <span class="preview-tag">Ejemplo</span>
          <div class="preview-top">
            <div class="preview-gauge">
              <svg viewBox="0 0 140 140" class="preview-gauge-svg">
                <circle class="pg-track" cx="70" cy="70" r="63" fill="none" stroke-width="14"></circle>
                <circle
                  class="pg-prog"
                  cx="70"
                  cy="70"
                  r="63"
                  fill="none"
                  stroke-width="14"
                  stroke-linecap="round"
                  stroke-dasharray="395.84"
                  stroke-dashoffset="110.84"
                ></circle>
              </svg>
              <div class="preview-gauge-center">
                <span class="pg-num">72</span><span class="pg-den">/ 100</span>
              </div>
            </div>
            <div class="preview-verdict">
              <div class="verdict-eyebrow">Tu puntaje GEO</div>
              <p class="verdict-text">Vas por buen camino, pero las IA todavía pierden señales clave de tu negocio.</p>
            </div>
          </div>

          <h3 class="section-title">Qué mejorar (en orden de impacto)</h3>
          <div class="recs">
            <div class="rec">
              <div class="ico">1</div>
              <p>Tu sitio no dice con claridad en qué ciudad o zona operas, así que las IA no saben a quién recomendarte por ubicación.</p>
            </div>
            <div class="rec">
              <div class="ico">2</div>
              <p>Falta una sección de preguntas frecuentes que la IA pueda citar como respuesta directa cuando alguien pregunta por tu rubro.</p>
            </div>
            <div class="rec">
              <div class="ico">3</div>
              <p>Tu página de inicio no explica en una sola frase qué vende tu negocio, lo que confunde a la IA al describirte.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== Cómo funciona ===== -->
    <section class="section" id="how">
      <div class="container">
        <div class="section-head">
          <span class="section-kicker">Cómo funciona</span>
          <h2>Tres pasos, sin instalar nada</h2>
          <p class="sub">De tu URL al diagnóstico completo en menos de un minuto.</p>
        </div>
        <div class="steps">
          <article class="step card">
            <span class="num">1</span>
            <h3>Pega tu dirección</h3>
            <p>Escribe la web de tu negocio, confirma que eres humano con un clic y listo.</p>
          </article>
          <article class="step card">
            <span class="num">2</span>
            <h3>Analizamos como una IA</h3>
            <p>Revisamos si las IA pueden leerte, entender qué ofreces y dónde operas.</p>
          </article>
          <article class="step card">
            <span class="num">3</span>
            <h3>Recibe tu plan</h3>
            <p>Un puntaje claro y recomendaciones concretas, en lenguaje de negocio.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- ===== Para quién es ===== -->
    <section class="section section-alt" id="industries">
      <div class="container">
        <div class="section-head">
          <span class="section-kicker">Para quién es</span>
          <h2>Cualquier negocio que quiera ser recomendado por las IA</h2>
          <p class="sub">Algunos ejemplos de quién se beneficia hoy de aparecer en respuestas de IA.</p>
        </div>
        <div class="industries">
          {
            industries.map((it) => (
              <article class="industry card">
                <h3>{it.title}</h3>
                <p class="who">{it.who}</p>
                <p class="how">{it.how}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ===== Metodología ===== -->
    <section class="section" id="method">
      <div class="container">
        <div class="section-head">
          <span class="section-kicker">Metodología</span>
          <h2>Cómo calculamos tu puntaje</h2>
          <p class="sub">
            Sin caja negra. Tu puntaje de 0 a 100 combina dos partes: un análisis técnico
            (40%) y un análisis del contenido hecho por IA (60%).
          </p>
        </div>
        <div class="method">
          <article class="method-card card">
            <div class="method-head">
              <h3>Análisis técnico</h3>
              <span class="method-weight">40%</span>
            </div>
            <p class="method-intro">Revisamos señales objetivas de tu sitio, cada una con su peso:</p>
            <ul class="method-list">
              {
                techChecks.map((c) => (
                  <li class="method-row">
                    <span class="method-wt">{c.w} pts</span>
                    <span class="lbl">{c.label}</span>
                  </li>
                ))
              }
            </ul>
            <p class="method-note-inline">
              Si tu sitio les impide la entrada a los robots de IA, el resto pasa a segundo
              plano y el puntaje queda topado: sin acceso, no hay forma de que te recomienden.
            </p>
          </article>

          <article class="method-card card">
            <div class="method-head">
              <h3>Análisis de contenido (IA)</h3>
              <span class="method-weight">60%</span>
            </div>
            <p class="method-intro">Una IA evalúa tu contenido en cuatro dimensiones y promedia el resultado:</p>
            <ul class="method-list">
              {
                dimensions.map((d) => (
                  <li class="method-row dim">
                    <span class="lbl"><strong>{d.name}.</strong> {d.desc}</span>
                  </li>
                ))
              }
            </ul>
            <p class="method-note-inline">
              Cada dimensión se mide contra criterios explícitos, no contra una opinión libre:
              el mismo contenido obtiene siempre el mismo número.
            </p>
          </article>
        </div>
      </div>
    </section>

    <!-- ===== Por qué confiar ===== -->
    <section class="section" id="confianza">
      <div class="container">
        <div class="section-head">
          <span class="section-kicker">Por qué confiar</span>
          <h2>Un diagnóstico que puedes auditar tú mismo</h2>
          <p class="sub">
            No te pedimos que creas en una caja negra. Esto es lo que hace que el análisis sea confiable.
          </p>
        </div>

        <div class="features-grid">
          <article class="feature card">
            <span class="feature-ico" aria-hidden="true">🔓</span>
            <h3>Código abierto</h3>
            <p>
              Todo el análisis está publicado en <a href={GITHUB_URL} rel="me">GitHub</a>. Puedes
              revisar exactamente cómo se calcula tu puntaje — sin secretos ni humo.
            </p>
          </article>
          <article class="feature card">
            <span class="feature-ico" aria-hidden="true">🎯</span>
            <h3>Puntaje reproducible</h3>
            <p>
              Mismo sitio, mismo número. Cada dimensión se mide contra criterios explícitos,
              no contra una opinión que cambia cada vez.
            </p>
          </article>
          <article class="feature card">
            <span class="feature-ico" aria-hidden="true">🔒</span>
            <h3>Tus datos son tuyos</h3>
            <p>
              Solo pedimos tu correo para enviarte el informe. No creamos cuentas, ni compartimos
              ni vendemos tu información a nadie.
            </p>
          </article>
          <article class="feature card">
            <span class="feature-ico" aria-hidden="true">🤝</span>
            <h3>Hecho por un dev real</h3>
            <p>
              Detrás está <a href={AUTHOR_URL} rel="author">Lukas Ibáñez</a>, con experiencia real en
              infraestructura, SEO y sitios en producción — no una agencia anónima ni un bot.
            </p>
          </article>
        </div>

        {/*
          ===== TESTIMONIOS (scaffold listo para cuando tengas reseñas REALES) =====
          Descomenta este bloque y reemplaza el contenido de `testimonials` (arriba,
          en el frontmatter) con frases de clientes reales que autorizaron mostrarlas.
          NO inventar testimonios: la prueba social falsa destruye la confianza si se
          descubre. Estructura sugerida en el array:
            const testimonials = [
              { quote: 'Frase textual del cliente.', name: 'Nombre Apellido', role: 'Cargo, Empresa' },
            ];

          <div class="testimonials">
            {testimonials.map((t) => (
              <figure class="testimonial card">
                <blockquote>{t.quote}</blockquote>
                <figcaption>
                  <strong>{t.name}</strong>
                  <span>{t.role}</span>
                </figcaption>
              </figure>
            ))}
          </div>
        */}
      </div>
    </section>

    <!-- ===== Reporte premium ===== -->
    <section class="section premium" id="premium">
      <div class="container">
        <div class="section-head">
          <span class="section-kicker">Reporte premium</span>
          <h2>El análisis completo, con plan de acción y competencia</h2>
          <p class="sub">
            El escaneo gratis te dice dónde estás parado. El reporte premium te dice exactamente
            qué hacer, en qué orden y cómo te comparas con tu competencia.
          </p>
        </div>

        <div class="premium-card card">
          <div class="premium-includes">
            <h3>Qué incluye</h3>
            <ul>
              <li><strong>Resumen ejecutivo:</strong> 3 fortalezas, 3 brechas y un veredicto directo sobre tu sitio.</li>
              <li><strong>Diagnóstico por dimensión:</strong> qué significa cada puntaje en tu negocio concreto y qué te cuesta dejarlo así.</li>
              <li><strong>Plan de acción priorizado:</strong> qué hacer primero, con el impacto, el esfuerzo y el plazo de cada acción.</li>
              <li><strong>Cómo te describiría una IA hoy</strong> a un cliente que le pide una recomendación en tu rubro.</li>
              <li><strong>Comparativa con hasta 3 competidores</strong>, medidos con la misma vara, y qué hace cada uno que a ti te falta.</li>
              <li><strong>Las preguntas que tus clientes le hacen a una IA</strong> y si tu sitio tiene contenido para responderlas.</li>
              <li><strong>Reporte PDF profesional</strong> listo para imprimir o compartir, más el informe completo en tu correo.</li>
            </ul>
          </div>

          <div class="premium-buy">
            <div class="premium-price">
              <span class="amount">US$5</span>
              <span class="per">pago único por sitio</span>
            </div>
            <p class="premium-how">
              Escríbeme, recibe tu código de acceso y desbloquea el informe completo en tu
              próximo escaneo. Sin suscripciones.
            </p>
            <a class="btn btn-primary btn-lg" href={`${AUTHOR_URL}/#servicios`}>
              Quiero mi reporte premium
              <span class="arrow" aria-hidden="true">→</span>
            </a>
            <a class="btn btn-ghost" href="/scan">Primero escanear gratis</a>
            <p class="premium-note">
              ¿Prefieres que las mejoras las implemente alguien por ti? Ese es justamente
              mi servicio: el reporte te dice qué hacer y yo me encargo del cómo.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== FAQ ===== -->
    <section class="section section-alt" id="faq">
      <div class="container">
        <div class="section-head">
          <span class="section-kicker">FAQ</span>
          <h2>Preguntas frecuentes</h2>
          <p class="sub">Lo que la gente suele preguntar sobre GEO y esta herramienta.</p>
        </div>
        <div class="faq">
          {
            faqs.map((f) => (
              <details class="faq-item">
                <summary>{f.q}</summary>
                <p>{f.a}</p>
              </details>
            ))
          }
        </div>

        <div class="section-cta">
          <p class="cta-line">¿Listo para ver cómo te ven las IA?</p>
          <a class="btn btn-primary btn-lg" href="/scan">
            Empezar mi diagnóstico gratis
            <span class="arrow" aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>
  </main>
</Base>
