---
import Base from '../layouts/Base.astro';
import ScanForm from '../components/ScanForm.astro';

// Landing estática (irónicamente, debe estar bien optimizada para GEO ella misma).
export const prerender = true;

// Flujo de captura del correo. 'one-step' = correo junto a la URL.
// 'two-step' = puntaje gratis + correo para recibir el informe completo.
const REVEAL_FLOW: 'one-step' | 'two-step' = 'two-step';

const SITE = 'https://geo.lukasibanez.dev';
const AUTHOR_URL = 'https://lukasibanez.dev';
const GITHUB_URL = 'https://github.com/Lukas-Ibanez';

// FAQ: una sola fuente de verdad → se renderiza visible y alimenta el schema FAQPage.
const faqs = [
  {
    q: '¿Qué es GEO?',
    a: 'GEO (Generative Engine Optimization) es optimizar tu sitio para aparecer y ser citado en las respuestas de los buscadores con IA, como ChatGPT, Perplexity, Gemini y los resúmenes de IA de Google. En vez de competir solo por un lugar en la lista de enlaces, buscas que la IA te entienda y te recomiende dentro de su respuesta.',
  },
  {
    q: '¿En qué se diferencia del SEO?',
    a: 'El SEO busca posicionar tu página entre los enlaces azules de Google. El GEO busca que la inteligencia artificial comprenda qué ofreces, confíe en tu sitio y te cite cuando alguien pregunta por lo que vendes. Son complementarios: un buen SEO ayuda, pero no garantiza que la IA te mencione.',
  },
  {
    q: '¿Es gratis?',
    a: 'Sí. El escaneo, el puntaje y el informe con recomendaciones son gratis. Solo te pido tu correo para enviarte el informe completo y el plan de mejoras; no necesitas crear una cuenta.',
  },
  {
    q: '¿Qué necesito para usarlo?',
    a: 'Solo la dirección de tu sitio web. No tienes que instalar nada, ni configurar nada, ni dar acceso a tus cuentas. Pegas la URL y en segundos tienes tu diagnóstico.',
  },
  {
    q: '¿Cómo se calcula el puntaje?',
    a: 'Analizamos tu sitio como lo haría una IA: si los robots de IA pueden leerlo, si queda claro qué ofreces y en qué zona operas, y qué tan citable y confiable es tu contenido. Combinamos esas señales en un puntaje de 0 a 100 con recomendaciones en lenguaje de negocio.',
  },
  {
    q: '¿Qué hacen con mis datos?',
    a: 'Guardamos tu correo y la URL escaneada para enviarte el informe y, si te interesa, contarte cómo implementar las mejoras. No compartimos ni vendemos tu información.',
  },
];

// Casos de uso / industrias. Datos editables: cambia o agrega entradas aquí.
const industries = [
  {
    title: 'Servicios locales',
    who: 'Clínicas, talleres, estudios, salones y oficios.',
    how: 'Cuando alguien le pide a una IA un servicio "cerca de mí", gana el negocio cuya web deja clarísimo qué hace y en qué zona atiende. El GEO se asegura de que ese seas tú.',
  },
  {
    title: 'Tiendas y e-commerce',
    who: 'Comercios con venta online o con local físico.',
    how: 'Las IA recomiendan productos y tiendas dentro de su respuesta. Si tu catálogo y tu propuesta están bien explicados, te citan en vez de mandar al cliente a la competencia.',
  },
  {
    title: 'Profesionales y consultores',
    who: 'Abogados, contadores, agencias, coaches y freelancers.',
    how: 'Tu experiencia es tu activo. El GEO la traduce en señales que la IA reconoce y cita cuando alguien busca a un experto en tu tema.',
  },
  {
    title: 'Turismo y hospitalidad',
    who: 'Hoteles, restaurantes, tours y arriendos.',
    how: 'Los viajeros planifican preguntándole a la IA. Un sitio claro sobre qué ofreces y dónde estás hace que te incluya en sus recomendaciones de viaje.',
  },
];

// Metodología: refleja el puntaje real (técnico 40% + contenido 60%).
// Los pesos del bloque técnico salen de src/lib/technicalScore.ts.
const techChecks = [
  { w: 25, label: 'Las IA pueden leer tu sitio (no bloqueas a sus robots)' },
  { w: 15, label: 'Datos estructurados que describen tu negocio' },
  { w: 12, label: 'Título de página claro y de buen largo' },
  { w: 12, label: 'Descripción que resume de qué trata el sitio' },
  { w: 12, label: 'Un encabezado principal único' },
  { w: 8, label: 'Listo para verse y citarse bien al compartirlo' },
  { w: 6, label: 'Señala cuál es la versión oficial de cada página' },
  { w: 5, label: 'Mapa del sitio (sitemap) para descubrir sus páginas' },
  { w: 5, label: 'Archivo llms.txt que orienta a las IA' },
];

// Las 4 dimensiones de contenido (ver src/lib/contentShared.ts), promediadas.
const dimensions = [
  { name: 'Claridad de negocio', desc: 'Si queda explícito qué vendes y para quién desde el primer bloque de texto.' },
  { name: 'Citabilidad', desc: 'Si tu contenido está estructurado en respuestas claras que una IA pueda extraer y citar.' },
  { name: 'Autoridad', desc: 'Si hay señales verificables de experiencia: años, clientes, cifras, casos o reseñas.' },
  { name: 'Claridad geográfica', desc: 'Si se entiende en qué ciudad o zona operas (o si claramente eres un negocio 100% digital).' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': `${AUTHOR_URL}/#lukas`,
      name: 'Lukas Ibáñez',
      url: AUTHOR_URL,
      jobTitle: 'Desarrollador web',
      description:
        'Desarrollador web con experiencia real en infraestructura, SEO y sitios en producción. Optimiza sitios para que las IA los encuentren, entiendan y recomienden (GEO).',
      knowsAbout: [
        'GEO (Generative Engine Optimization)',
        'SEO',
        'Desarrollo web',
        'Infraestructura web',
        'Cloudflare',
      ],
      sameAs: [AUTHOR_URL, GITHUB_URL],
    },
    {
      '@type': 'Organization',
      '@id': `${AUTHOR_URL}/#organization`,
      name: 'Lukas Ibáñez',
      url: AUTHOR_URL,
      founder: { '@id': `${AUTHOR_URL}/#lukas` },
      areaServed: ['CL', 'Latinoamérica', 'España'],
      knowsLanguage: 'es',
      sameAs: [GITHUB_URL],
      description:
        'Desarrollo web y optimización para buscadores con IA (GEO), con base en Chile y enfoque en negocios de habla hispana.',
    },
    {
      '@type': 'WebApplication',
      '@id': `${SITE}/#webapp`,
      name: 'GEO Scanner',
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Web',
      inLanguage: 'es-CL',
      url: SITE,
      description:
        'Herramienta gratuita que audita qué tan preparado está tu sitio web para aparecer en respuestas de IA como ChatGPT, Perplexity, Gemini y Google AI Overviews. Hecha en Chile para negocios de habla hispana.',
      isAccessibleForFree: true,
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      author: { '@id': `${AUTHOR_URL}/#lukas` },
      creator: { '@id': `${AUTHOR_URL}/#lukas` },
      publisher: { '@id': `${AUTHOR_URL}/#organization` },
      audience: {
        '@type': 'Audience',
        audienceType: 'Dueños de negocios y emprendedores de habla hispana',
        geographicArea: { '@type': 'Place', name: 'Latinoamérica y España' },
      },
    },
    {
      '@type': 'FAQPage',
      '@id': `${SITE}/#faq`,
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
  ],
};
---

<Base>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />

  <header class="site-header">
    <div class="container">
      <a class="brand" href="/"><span class="dot" aria-hidden="true"></span> GEO Scanner</a>
    </div>
  </header>

  <main>
    <section class="hero">
      <div class="container">
        <span class="eyebrow"><span class="pulse"></span> Optimización para buscadores con IA (GEO)</span>
        <h1>¿Te encuentran <span class="grad">las IA</span> cuando alguien busca lo que vendes?</h1>
        <p class="lead">
          Escanea tu sitio gratis y descubre qué tan preparado está para aparecer en ChatGPT,
          Perplexity, Gemini y Google AI — con un puntaje claro y qué mejorar, sin tecnicismos.
        </p>

        <div class="scan-card card">
          <ScanForm revealFlow={REVEAL_FLOW} />
        </div>

        <ul class="trust">
          <li class="chk">✓ Gratis</li>
          <li class="sep">·</li>
          <li class="chk">✓ En segundos</li>
          <li class="sep">·</li>
          <li class="engines">
            <span class="engine">ChatGPT</span>
            <span class="engine">Perplexity</span>
            <span class="engine">Gemini</span>
            <span class="engine">Google AI</span>
          </li>
        </ul>

        <p class="author-trust">
          Hecho en Chile por <a href={AUTHOR_URL} rel="author">Lukas Ibáñez</a>, desarrollador web con
          experiencia real en infraestructura, SEO y sitios en producción —
          los mismos fundamentos con que se construyó esta herramienta. Pensada para negocios de
          habla hispana en Latinoamérica y España. <a href={GITHUB_URL} rel="me">Ver código y proyectos</a>.
        </p>
      </div>
    </section>

    <section class="container">
      <!-- La island renderiza aquí el loading y el resultado -->
      <div id="scan-output" hidden></div>
    </section>

    <!-- Muestra estática de cómo se ve el informe (preview, no es un resultado real) -->
    <section class="section">
      <div class="container">
        <div class="preview-head section-center">
          <h2>Así se ve tu informe</h2>
          <p class="sub">Un puntaje claro y recomendaciones en lenguaje de negocio. Esto es un ejemplo.</p>
        </div>

        <div class="preview-card card" aria-hidden="true">
          <span class="preview-tag">Ejemplo</span>
          <div class="preview-top">
            <div class="preview-gauge">
              <svg viewBox="0 0 140 140" class="preview-gauge-svg">
                <circle class="pg-track" cx="70" cy="70" r="63" fill="none" stroke-width="14"></circle>
                <circle
                  class="pg-prog"
                  cx="70"
                  cy="70"
                  r="63"
                  fill="none"
                  stroke-width="14"
                  stroke-linecap="round"
                  stroke-dasharray="395.84"
                  stroke-dashoffset="110.84"
                ></circle>
              </svg>
              <div class="preview-gauge-center">
                <span class="pg-num">72</span><span class="pg-den">/ 100</span>
              </div>
            </div>
            <div class="preview-verdict">
              <div class="verdict-eyebrow">Tu puntaje GEO</div>
              <p class="verdict-text">Vas por buen camino, pero las IA todavía pierden señales clave de tu negocio.</p>
            </div>
          </div>

          <h3 class="section-title">Qué mejorar (en orden de impacto)</h3>
          <div class="recs">
            <div class="rec">
              <div class="ico">1</div>
              <p>Tu sitio no dice con claridad en qué ciudad o zona operas, así que las IA no saben a quién recomendarte por ubicación.</p>
            </div>
            <div class="rec">
              <div class="ico">2</div>
              <p>Falta una sección de preguntas frecuentes que la IA pueda citar como respuesta directa cuando alguien pregunta por tu rubro.</p>
            </div>
            <div class="rec">
              <div class="ico">3</div>
              <p>Tu página de inicio no explica en una sola frase qué vende tu negocio, lo que confunde a la IA al describirte.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section section-center">
      <div class="container">
        <h2>Cómo funciona</h2>
        <p class="sub">En tres pasos simples obtienes un diagnóstico claro de tu visibilidad ante las IA.</p>
        <div class="steps">
          <article class="step card">
            <span class="num">1</span>
            <h3>Pega tu dirección</h3>
            <p>Escribe la web de tu negocio. No necesitas instalar ni configurar nada.</p>
          </article>
          <article class="step card">
            <span class="num">2</span>
            <h3>Analizamos como una IA</h3>
            <p>Revisamos si las IA pueden leerte, entender qué ofreces y dónde operas.</p>
          </article>
          <article class="step card">
            <span class="num">3</span>
            <h3>Recibe tu plan</h3>
            <p>Un puntaje claro y recomendaciones concretas, en lenguaje de negocio.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-center">
          <h2>Para quién es</h2>
          <p class="sub">El GEO ayuda a cualquier negocio que quiera que las IA lo entiendan y lo recomienden. Algunos ejemplos:</p>
        </div>
        <div class="industries">
          {
            industries.map((it) => (
              <article class="industry card">
                <h3>{it.title}</h3>
                <p class="who">{it.who}</p>
                <p class="how">{it.how}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-center">
          <h2>Cómo calculamos tu puntaje</h2>
          <p class="sub">
            Sin caja negra. Tu puntaje de 0 a 100 combina dos partes: un análisis técnico
            (40%) y un análisis del contenido hecho por IA (60%).
          </p>
        </div>
        <div class="method">
          <article class="method-card card">
            <div class="method-head">
              <h3>Análisis técnico</h3>
              <span class="method-weight">40%</span>
            </div>
            <p class="method-intro">Revisamos señales objetivas de tu sitio, cada una con su peso:</p>
            <ul class="method-list">
              {
                techChecks.map((c) => (
                  <li class="method-row">
                    <span class="method-wt">{c.w} pts</span>
                    <span class="lbl">{c.label}</span>
                  </li>
                ))
              }
            </ul>
            <p class="method-note-inline">
              Si tu sitio les impide la entrada a los robots de IA, el resto pasa a segundo
              plano y el puntaje queda topado: sin acceso, no hay forma de que te recomienden.
            </p>
          </article>

          <article class="method-card card">
            <div class="method-head">
              <h3>Análisis de contenido (IA)</h3>
              <span class="method-weight">60%</span>
            </div>
            <p class="method-intro">Una IA evalúa tu contenido en cuatro dimensiones y promedia el resultado:</p>
            <ul class="method-list">
              {
                dimensions.map((d) => (
                  <li class="method-row dim">
                    <span class="lbl"><strong>{d.name}.</strong> {d.desc}</span>
                  </li>
                ))
              }
            </ul>
            <p class="method-note-inline">
              Cada dimensión se mide contra criterios explícitos, no contra una opinión libre:
              el mismo contenido obtiene siempre el mismo número.
            </p>
          </article>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-center">
          <h2>Preguntas frecuentes</h2>
          <p class="sub">Lo que la gente suele preguntar sobre GEO y esta herramienta.</p>
        </div>
        <div class="faq">
          {
            faqs.map((f) => (
              <details class="faq-item">
                <summary>{f.q}</summary>
                <p>{f.a}</p>
              </details>
            ))
          }
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container">
      <p>
        GEO Scanner · una herramienta de <a href={AUTHOR_URL}>lukasibanez.dev</a> ·
        <a href={GITHUB_URL}>GitHub</a><br />
        Hecho en Chile 🇨🇱 para negocios de habla hispana en Latinoamérica y España.
      </p>
    </div>
  </footer>

  <script>
    import { initScanner } from '../scripts/scanner-island';
    initScanner();
  </script>
</Base>
