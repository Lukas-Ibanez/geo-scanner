---
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  /** Identificador de página para marcar el link activo en la nav. */
  active?: 'home' | 'scan' | 'report' | 'about';
}

const {
  title = 'GEO Scanner — ¿Te encuentran las IA? Audita tu sitio gratis',
  description = 'Escanea tu sitio gratis y descubre si las IA (ChatGPT, Perplexity, Gemini, Google AI) están listas para recomendarte. Puntaje claro y plan de mejoras.',
  active = 'home',
} = Astro.props;

const site = Astro.site ?? new URL('https://geo.lukasibanez.dev');
const canonical = new URL(Astro.url.pathname, site).toString();
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index,follow" />
    <meta name="theme-color" content="#f7f4ee" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="GEO Scanner" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="es_CL" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <slot name="head" />
  </head>
  <body data-page={active}>
    <!-- blobs pastel de fondo (decorativos) -->
    <div class="bg-blobs" aria-hidden="true">
      <span class="blob blob-1"></span>
      <span class="blob blob-2"></span>
      <span class="blob blob-3"></span>
    </div>

    <SiteNav active={active} />

    <slot />

    <SiteFooter />
  </body>
</html>
