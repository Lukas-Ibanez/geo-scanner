---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'GEO Scanner — ¿Te encuentran las IA? Audita tu sitio gratis',
  description = 'Escanea tu sitio web gratis y descubre qué tan preparado está para aparecer en respuestas de ChatGPT, Perplexity, Gemini y Google AI. Puntaje claro y recomendaciones en segundos.',
} = Astro.props;

const site = Astro.site ?? new URL('https://geo.lukasibanez.dev');
const canonical = new URL(Astro.url.pathname, site).toString();

import '../styles/global.css';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index,follow" />
    <meta name="theme-color" content="#3b6ef6" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="GEO Scanner" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="es_ES" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
